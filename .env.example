DISCORD_TOKEN="YOUR_DISCORD_USER_TOKEN"
MAIN_WEBHOOK="https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN"
ERROR_WEBHOOK="https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN"
GITHUB_TOKEN="ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
REPOSITORY="YOUR_USERNAME/YOUR_REPO_NAME"
PING_ROLE_ID=""
LOCALE="en-US"
# Optional: proxy list for country-cycling quest fetches.
# PROXY_LIST_URL: a raw URL (e.g. a Gist raw link) to fetch the list from at
#   runtime — use this if the list is too big for a GitHub secret (secrets
#   have a size limit). Checked first.
# PROXY_LIST: the list inline (JSON array, JSON {"proxies":[...]}, or a
#   plain newline/comma-separated list of proxy URLs). Fine for short lists.
#   Checked if PROXY_LIST_URL isn't set or returns nothing.
# Both accept proxy URLs like https://user:pass@host:port. Keep whichever
# you use in a GitHub secret — never commit real values in proxy.json.
PROXY_LIST_URL=""
PROXY_LIST=""
